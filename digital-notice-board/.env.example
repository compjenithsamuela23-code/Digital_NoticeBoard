SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
SUPABASE_STORAGE_BUCKET=notice-board-uploads
# Optional: comma-separated list of allowed frontend origins for CORS/socket
# CLIENT_ORIGIN=https://your-app.onrender.com
# Optional production hardening
# TRUST_PROXY=1
# API_NO_STORE=true
# Optional AI ops agent automation
# OPS_AGENT_AUTOFIX_ENABLED=true
# OPS_AGENT_INTERVAL_MS=60000
# OPS_AGENT_COOLDOWN_MS=300000
# OPS_AGENT_ACTION_TIMEOUT_MS=180000
# GitHub / Vercel integration for controlled repair actions
# GITHUB_REPO=your-account/your-repo
# GITHUB_TOKEN=ghp_xxx
# GITHUB_ACTIONS_WORKFLOW_ID=deploy.yml
# GITHUB_ACTIONS_REF=main
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Client (set in `client/.env` or hosting provider frontend env settings):
# VITE_API_BASE_URL=https://your-backend-domain.com
# VITE_ENABLE_SOCKET=false
